      *   DEFINICIONES DB2
           EXEC SQL
              INCLUDE SQLCA
           END-EXEC.

           EXEC SQL
              INCLUDE TBCURCLI
           END-EXEC.

           EXEC SQL
              INCLUDE TBCURCTA
           END-EXEC.

           EXEC SQL
              DECLARE ITEM-CURSOR CURSOR FOR

              SELECT
                    B.SEXO,
                    A.TIPCUEN,
                    A.NROCUEN,
                    A.SUCUEN,
                    A.NROCLI,
                    B.NOMAPE,
                    A.SALDO,
                    A.FECSAL
              FROM  KC02803.TBCURCTA A
              INNER JOIN
                    KC02803.TBCURCLI B
                    ON A.NROCLI = B.NROCLI
              WHERE A.SALDO > 0
              ORDER BY B.SEXO, A.TIPCUEN

           END-EXEC.

       PROCEDURE DIVISION.                                              01240004
